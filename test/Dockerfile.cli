# KeyHaven CLI Dockerfile
FROM rust:1.75-slim-bookworm AS builder

WORKDIR /build

# Install dependencies required for building
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy the entire workspace
COPY Cargo.toml ./
COPY vault-core ./vault-core
COPY vault-cli ./vault-cli

# Build the CLI in release mode
RUN cargo build --release -p vault-cli

# Runtime stage
FROM debian:bookworm-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libsqlite3-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 keyhaven

# Copy the built binary from builder
COPY --from=builder /build/target/release/keyhaven /app/keyhaven

# Create directories for vault data and config
RUN mkdir -p /data /config /run/keyhaven && \
    chown -R keyhaven:keyhaven /data /config /run/keyhaven /app

USER keyhaven

# Environment variables
ENV VAULT_DB_PATH=/data/vault.db
ENV VAULT_SOCKET_PATH=/run/keyhaven/daemon.sock

# Default command shows help
CMD ["/app/keyhaven", "--help"]
