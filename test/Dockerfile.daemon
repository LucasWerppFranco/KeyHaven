# KeyHaven Daemon Dockerfile
FROM rust:1.86-slim-bookworm AS builder

WORKDIR /build

# Install dependencies required for building
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy workspace source code
COPY vault-core ./vault-core
COPY vault-daemon ./vault-daemon
COPY vault-cli ./vault-cli

# Create a minimal workspace Cargo.toml (without vault-desktop)
RUN echo '[workspace]' > Cargo.toml && \
    echo 'members = ["vault-core", "vault-daemon", "vault-cli"]' >> Cargo.toml && \
    echo 'resolver = "2"' >> Cargo.toml && \
    echo '' >> Cargo.toml && \
    echo '[workspace.dependencies]' >> Cargo.toml && \
    echo 'serde = { version = "1", features = ["derive"] }' >> Cargo.toml && \
    echo 'serde_json = "1"' >> Cargo.toml && \
    echo 'tokio = { version = "1", features = ["full"] }' >> Cargo.toml && \
    echo 'anyhow = "1"' >> Cargo.toml && \
    echo 'thiserror = "1"' >> Cargo.toml && \
    echo 'zeroize = { version = "1", features = ["derive"] }' >> Cargo.toml && \
    echo 'log = "0.4"' >> Cargo.toml && \
    echo 'sqlx = { version = "0.7", features = ["sqlite", "runtime-tokio"] }' >> Cargo.toml && \
    echo 'aes-gcm = "0.10"' >> Cargo.toml && \
    echo 'argon2 = "0.5"' >> Cargo.toml && \
    echo 'rand = "0.8"' >> Cargo.toml && \
    echo 'hmac = "0.12"' >> Cargo.toml && \
    echo 'sha2 = "0.10"' >> Cargo.toml

# Update dependencies to get compatible versions and build
RUN cargo update && cargo build --release -p vault-daemon

# Runtime stage
FROM debian:bookworm-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libsqlite3-0 \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN useradd -m -u 1000 keyhaven

# Copy the built binary from builder
COPY --from=builder /build/target/release/vault-daemon /app/vault-daemon

# Create directories for vault data and config
RUN mkdir -p /data /config /run/keyhaven && \
    chown -R keyhaven:keyhaven /data /config /run/keyhaven /app

USER keyhaven

# Expose the Unix socket directory (mounted as volume)
VOLUME ["/data", "/config", "/run/keyhaven"]

# Environment variables
ENV VAULT_DB_PATH=/data/vault.db
ENV VAULT_SOCKET_PATH=/run/keyhaven/daemon.sock
ENV RUST_LOG=info

# Start the daemon
CMD ["/app/vault-daemon"]
